        "responses": { "201": { "description": "Lead created successfully" } }
      }
    },
    "/leads/{id}": {
      "get": {
        "summary": "Get lead by ID",
        "tags": ["Leads"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Lead details" }, "404": { "description": "Lead not found" } }
      },
      "put": {
        "summary": "Update lead",
        "tags": ["Leads"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "$ref": "#/components/schemas/Lead" } } },
        "responses": { "200": { "description": "Lead updated successfully" } }
      },
      "delete": {
        "summary": "Delete lead",
        "tags": ["Leads"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Lead deleted successfully" } }
      }
    },

    "/leads/stats": {
      "get": {
        "summary": "Get lead statistics",
        "tags": ["Leads"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Lead stats data" } }
      }
    },

    "/lead-sources": {
      "get": {
        "summary": "Get all lead sources",
        "tags": ["Lead Sources"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "List of lead sources" } }
      },
      "post": {
        "summary": "Create lead source",
        "tags": ["Lead Sources"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "$ref": "#/components/schemas/LeadSource" } } },
        "responses": { "201": { "description": "Lead source created successfully" } }
      }
    },
    "/lead-sources/{id}": {
      "put": {
        "summary": "Update lead source",
        "tags": ["Lead Sources"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "$ref": "#/components/schemas/LeadSource" } } },
        "responses": { "200": { "description": "Lead source updated successfully" } }
      },
      "delete": {
        "summary": "Delete lead source",
        "tags": ["Lead Sources"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Lead source deleted successfully" } }
      }
    },

    "/activities": {
      "get": {
        "summary": "Get all activities",
        "tags": ["Activities"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "List of activities" } }
      },
      "post": {
        "summary": "Create activity",
        "tags": ["Activities"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "$ref": "#/components/schemas/Activity" } } },
        "responses": { "201": { "description": "Activity created successfully" } }
      }
    },
    "/activities/recent": {
      "get": {
        "summary": "Get recent activities",
        "tags": ["Activities"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Recent activities" } }
      }
    },
    "/activities/stats": {
      "get": {
        "summary": "Get activity statistics",
        "tags": ["Activities"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Activity stats" } }
      }
    },
    "/activities/deleted-data": {
      "get": {
        "summary": "Get deleted data",
        "tags": ["Activities"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Deleted data list" } }
      }
    },

    "/industries": {
      "get": {
        "summary": "Get all industries",
        "tags": ["Industries"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "List of industries" } }
      },
      "post": {
        "summary": "Create industry",
        "tags": ["Industries"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "$ref": "#/components/schemas/Industry" } } },
        "responses": { "201": { "description": "Industry created successfully" } }
      }
    },
    "/industries/{id}": {
      "put": {
        "summary": "Update industry",
        "tags": ["Industries"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "$ref": "#/components/schemas/Industry" } } },
        "responses": { "200": { "description": "Industry updated successfully" } }
      },
      "delete": {
        "summary": "Delete industry",
        "tags": ["Industries"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Industry deleted successfully" } }
      }
    },
    "/industries/{id}/fields": {
      "post": {
        "summary": "Add a field to industry",
        "tags": ["Industries"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "$ref": "#/components/schemas/IndustryField" } } },
        "responses": { "201": { "description": "Field added successfully" } }
      }
    },
    "/industries/fields/{fieldId}": {
      "put": {
        "summary": "Update industry field",
        "tags": ["Industries"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "fieldId", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "$ref": "#/components/schemas/IndustryField" } } },
        "responses": { "200": { "description": "Field updated successfully" } }
      },
      "delete": {
        "summary": "Delete industry field",
        "tags": ["Industries"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "in": "path", "name": "fieldId", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Field deleted successfully" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
          "password": { "type": "string" },
          "roleIds": { "type": "array", "items": { "type": "integer" } }
        },
        "required": ["firstName", "email", "password"]
      },
      "Lead": {
        "type": "object",
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "company": { "type": "string" },
          "position": { "type": "string" },
          "sourceId": { "type": "integer" },
          "status": { "type": "string", "enum": ["new","contacted","qualified","proposal","negotiation","closed","lost"] },
          "notes": { "type": "string" },
          "assignedTo": { "type": "integer" },
          "tags": { "type": "array", "items": { "type": "integer" } }
        },
        "required": ["firstName", "lastName", "email", "phone"]
      },
      "LeadSource": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["name"]
      },
      "Activity": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string" },
          "icon": { "type": "string" },
          "iconColor": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "metadata": { "type": "object" },
          "userId": { "type": "integer" }
        },
        "required": ["title", "type"]
      },
      "Industry": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["name"]
      },
      "IndustryField": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "options": { "type": "array", "items": { "type": "string" } },
          "isRequired": { "type": "boolean" }
        },
        "required": ["name", "type"]
      }
    }
  }
}
