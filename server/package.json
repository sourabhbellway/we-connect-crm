{
  "name": "crm-backend",
  "version": "1.0.0",
  "description": "CRM Authentication Backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:seed": "ts-node src/seeders/initialData.ts",
    "create:super-admin": "node createSuperAdmin.js",
    "create:super-admin:ts": "ts-node src/seeders/superAdminSeeder.ts",
    "verify:super-admin": "node verifySuperAdmin.js",
    "test:super-admin-login": "node testSuperAdminLogin.js"
  },
  "dependencies": {
    "@prisma/client": "^6.16.1",
    "@types/multer": "^2.0.0",
    "@types/react-toastify": "^4.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "react-toastify": "^11.0.5",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.0.2",
    "prisma": "^6.16.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
